{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Release (same as make)",
      "description": "Matches scripts/build.sh: cmake -S core -B build from repo root.",
      "generator": "Unix Makefiles",
      "binaryDir": "${fileDir}/build",
      "sourceDir": "${fileDir}/core",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    }
  ]
}
